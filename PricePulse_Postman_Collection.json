{
	"info": {
		"name": "PricePulse API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@user.com\",\n    \"password\": \"password123\",\n    \"name\": \"Tester\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "http://localhost:3010/api/auth/register"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"default@user.com\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "http://localhost:3010/api/auth/login"
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "Get Products",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "http://localhost:3010/api/products"
					}
				},
				{
					"name": "Create Product",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"url\": \"https://example.com/item\",\n    \"initialPrice\": 99.99\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "http://localhost:3010/api/products"
					}
				}
			]
		}
	]
}
